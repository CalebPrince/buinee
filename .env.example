# Ledgerline server configuration
#
# Copy this file to  .env  in this same folder, then fill in what you need.
# Keys stay on this machine and are never sent to the browser.
#
#   copy .env.example .env

# --- API keys for the landing page's demo agent (add at least one) --------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# --- Which provider to use -------------------------------------------------
# anthropic | google | openrouter
# Leave blank to auto-pick the first provider that has a key.
CLERK_PROVIDER=anthropic

# --- Model override --------------------------------------------------------
# Leave blank to use the provider default:
#   anthropic   claude-opus-4-8
#   google      gemini-3-pro
#   openrouter  anthropic/claude-opus-4.8
CLERK_MODEL=

# --- Connected mailboxes ---------------------------------------------------
# See the README's "Connecting a mailbox" section. Each provider is optional
# and independent: set up none, one, or all three. A provider with no keys
# simply isn't offered in the dashboard — nothing else breaks.
#
# REQUIRED for any mailbox at all. Encrypts stored mailbox credentials, so a
# copy of the database is useless without it. Generate one with:
#   python -c "import secretstore; print(secretstore.generate_key())"
# Needs:  pip install cryptography
# Changing this key makes every existing connection unreadable — people just
# reconnect, but don't rotate it casually.
BUINEE_SECRET_KEY=

# Outlook / Microsoft 365 — Azure app registration, multitenant.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
#   production   https://buinee.app/api/mailbox/callback
#   local dev    http://localhost:8080/api/mailbox/callback
AZURE_REDIRECT_URI=https://buinee.app/api/mailbox/callback

# Gmail / Google Workspace — Google Cloud OAuth client (Web application).
# Note: Gmail scopes are "restricted" — a production app needs Google
# verification plus an annual security assessment, and is capped at a handful
# of test users until that clears. Leave blank until that's done.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://buinee.app/api/mailbox/callback

# Paystack billing. Keep the secret key server-only in cPanel Environment Variables.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://buinee.app/api/paystack/callback
PAYSTACK_WEBHOOK_URL=https://buinee.app/api/paystack/webhook

# IMAP (company mail on cPanel, Zoho, Fastmail, Yahoo, Gmail-with-app-password)
# needs no keys at all — the person supplies their own server and password,
# so it works as soon as BUINEE_SECRET_KEY is set.

# Note: the platform owner's Command Center login (admin-login.html) is NOT
# configured here. It's a separate identity in its own database table
# (platform_admins), created directly via a script, not an env variable —
# see the README's Command Center section.
